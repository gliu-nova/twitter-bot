# FRED API key (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Coinglass API key (optional, free hobbyist tier): https://www.coinglass.com/pricing
# Enables full hourly liquidation backfill in market-memory.
COINGLASS_API_KEY=

# Coinalyze API key (free): https://coinalyze.net/account/api-key/
# Cross-verifies OKX/Binance liquidation spikes in market-memory sync/backfill.
COINALYZE_API_KEY=

# Twitter/X API (https://developer.x.com/)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
# Required to POST tweets (generate under Keys and tokens → Access Token and Secret):
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Set to 1 to print tweets instead of posting
DRY_RUN=1