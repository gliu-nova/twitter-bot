# FRED API key (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Twitter/X API (https://developer.x.com/)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
# Required to POST tweets (generate under Keys and tokens → Access Token and Secret):
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Set to 1 to print tweets instead of posting
DRY_RUN=1